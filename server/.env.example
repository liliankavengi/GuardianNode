PORT=3001
MOCK_MODE=false

# Africa's Talking Credentials
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key_here
AT_VIRTUAL_NUMBER=+254xxxxxxxxx

# The real admin mobile number that receives the voice call for high-risk transactions
AT_ADMIN_PHONE=+254xxxxxxxxx

# Your public ngrok/tunnel URL so Africa's Talking can reach your local server.
# Example: https://abc123.ngrok-free.app
# The voice callback will be called at: AT_CALLBACK_URL/api/voice/callback
# The USSD callback will be called at:  AT_CALLBACK_URL/api/ussd
AT_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_PUBLIC_KEY=your_stellar_public_key_here
STELLAR_SECRET_KEY=your_stellar_secret_key_here
